{
    "name": "tasks-map",
    "version": "0.32.2",
    "description": "A graph view of your tasks.",
    "main": "main.js",
    "engines": {
        "node": ">=24.0.0",
        "npm": ">=10.0.0"
    },
    "scripts": {
        "dev": "node esbuild.config.mjs",
        "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
        "test": "jest",
        "test:watch": "jest --watch",
        "test:coverage": "jest --coverage",
        "lint": "eslint 'src/**/*.{ts,tsx}'",
        "lint:fix": "eslint 'src/**/*.{ts,tsx}' --fix",
        "lint:css": "stylelint \"*.css\" \"src/**/*.css\"",
        "lint:css:fix": "stylelint \"*.css\" \"src/**/*.css\" --fix",
        "format": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
        "format:fix": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css,md}\""
    },
    "keywords": [],
    "author": "",
    "license": "MIT",
    "devDependencies": {
        "@eslint-react/eslint-plugin": "^5.7.8",
        "@eslint/js": "^10.0.0",
        "@types/jest": "^30.0.0",
        "@types/node": "^24.0.0",
        "@types/react": "^19.1.8",
        "@types/react-dom": "^19.1.6",
        "@typescript-eslint/eslint-plugin": "8.59.3",
        "@typescript-eslint/parser": "8.59.3",
        "esbuild": "0.28.0",
        "eslint": "^10.0.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-react-hooks": "^7.0.1",
        "globals": "^17.0.0",
        "jest": "^30.2.0",
        "obsidian": "latest",
        "prettier": "^3.6.2",
        "stylelint": "^17.11.1",
        "stylelint-config-standard": "^40.0.0",
        "ts-jest": "^29.4.5",
        "tslib": "2.8.1",
        "typescript": "5.9.3",
        "yaml": "^2.9.0"
    },
    "dependencies": {
        "@dagrejs/dagre": "^1.1.5",
        "i18next": "^26.0.0",
        "lucide-react": "^1.0.0",
        "react": "^19.1.0",
        "react-dom": "^19.1.0",
        "react-select": "^5.10.2",
        "reactflow": "^11.11.4"
    }
}