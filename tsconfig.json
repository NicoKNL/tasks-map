{
  "compilerOptions": {
    "jsx": "react-jsx",
    "inlineSourceMap": true,
    "inlineSources": true,
    "module": "ESNext",
    "target": "ES6",
    "allowJs": true,
    "noImplicitAny": true,
    "moduleResolution": "bundler",
    "paths": {
      "src/*": ["./src/*"]
    },
    "esModuleInterop": true,
    "strict": true,
    "importHelpers": true,
    "isolatedModules": true,
    "strictNullChecks": true,
    "resolveJsonModule": true,
    "lib": [
      "DOM",
      "ES5",
      "ES6",
      "ES7"
    ],
    "outDir": "./dist",
    "types": ["jest", "node"]
  },
  "include": ["src"],
  "exclude": ["test", "node_modules"]
}
